package {{ component.package }};

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
{% if use_assertj %}
import static org.assertj.core.api.Assertions.assertThat;
{% endif %}

// Inferred Imports
{% for imp in imports %}
import {{ imp }};
{% endfor %}

class {{ component.name }}Test {
    {% if component.is_record %}
    // Record instance is constructed per-test using its components.
    {% else %}

    private {{ component.name }} {{ sut_var }} = new {{ component.name }}();
    {% endif %}

    {% for method in component.methods %}
    @Test
    void {{ method.name }}_test(){% if method.throws_declared %} throws Exception{% endif %} {
        // Arrange
        {{ method.args_init_block | indent(8) }}

        // Act
        {% if method.return_type and method.return_type != 'void' %}
        {{ method.return_type }} result = {{ sut_var }}.{{ method.name }}({{ method.args | map(attribute='name') | join(', ') }});
        {% else %}
        {{ sut_var }}.{{ method.name }}({{ method.args | map(attribute='name') | join(', ') }});
        {% endif %}

        // Assert
        {% if method.assert_line %}
        {{ method.assert_line }}
        {% endif %}
    }

    {% for extra in method.extra_tests %}
    {{ extra | indent(4) }}

    {% endfor %}
    {% endfor %}
}
