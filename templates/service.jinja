package {{ component.package }};

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.mockito.Mockito.*;
import static org.mockito.ArgumentMatchers.*;
import static org.junit.jupiter.api.Assertions.*;
{% if use_assertj %}
import static org.assertj.core.api.Assertions.assertThat;
{% endif %}

// Inferred Imports
{% for imp in imports %}
import {{ imp }};
{% endfor %}

@ExtendWith(MockitoExtension.class)
class {{ component.name }}Test {

    {% for dep in component.dependencies %}
    @Mock
    private {{ dep.type }} {{ dep.name }};
    {% endfor %}

    @InjectMocks
    private {{ component.name }} {{ sut_var }};
    {% if ctor_fallback_block %}

    @BeforeEach
    void setUp() {
        {{ ctor_fallback_block | indent(8) }}
    }
    {% endif %}

    {% for method in component.methods %}
    @Test
    void {{ method.name }}_test(){% if method.throws_declared %} throws Exception{% endif %} {
        // Arrange
        {{ method.args_init_block | indent(8) }}
        {% if method.stubs_block %}
        {{ method.stubs_block | indent(8) }}
        {% endif %}

        // Act
        {% if method.return_type and method.return_type != 'void' %}
        {{ method.return_type }} result = {{ sut_var }}.{{ method.name }}({{ method.args | map(attribute='name') | join(', ') }});
        {% else %}
        {{ sut_var }}.{{ method.name }}({{ method.args | map(attribute='name') | join(', ') }});
        {% endif %}

        // Assert
        {% if method.assert_line %}
        {{ method.assert_line }}
        {% endif %}
        {% if method.verify_block %}
        {{ method.verify_block | indent(8) }}
        {% endif %}
    }

    {% for extra in method.extra_tests %}
    {{ extra | indent(4) }}

    {% endfor %}
    {% endfor %}
}
